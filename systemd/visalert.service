[Unit]
Description=Visa Appointment Alert System
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=bombadil
WorkingDirectory=/home/bombadil/visalert
ExecStart=/home/bombadil/venv/bin/python src/main.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
